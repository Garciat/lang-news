{
  "tasks": {
    "lume": "deno run --allow-read --allow-write --allow-net --allow-env --allow-run https://deno.land/x/lume@v1.19.4/cli.ts",
    "ingest": "deno run --allow-read --allow-write --allow-net scripts/news/generate.ts",
    "build": "deno task ingest && deno task lume",
    "serve": "deno task ingest && deno task lume -s"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.1.2",
    "@std/yaml": "jsr:@std/yaml@^1.0.5",
    "lume/": "https://deno.land/x/lume@v1.19.4/"
  }
}
