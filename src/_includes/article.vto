<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - Lang News</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f5f7fb;
      --surface: #ffffff;
      --text: #132238;
      --muted: #55657d;
      --border: #d6dfeb;
      --accent: #155eef;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: Inter, system-ui, sans-serif;
      line-height: 1.7;
    }
    a { color: var(--accent); }
    header, main, footer {
      max-width: 840px;
      margin: 0 auto;
      padding: 1.5rem;
    }
    .article-shell {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 1.5rem;
      box-shadow: 0 8px 24px rgba(19, 34, 56, 0.04);
    }
    .meta {
      color: var(--muted);
      margin: 0.25rem 0;
    }
    .body {
      margin-top: 1.5rem;
      white-space: pre-wrap;
    }
  </style>
</head>
<body>
  <header>
    <a href="/">← Back to Lang News</a>
  </header>
  <main>
    <article class="article-shell">
      <p class="meta">{{ language }} · {{ category }} · {{ date }}</p>
      <h1>{{ title }}</h1>
      <p class="meta">Source: <a href="{{ canonicalUrl }}">{{ sourceName }}</a></p>
      {{ if version }}<p class="meta">Version: {{ version }}</p>{{ /if }}
      {{ if updatedAt && updatedAt !== fetchedAt }}<p class="meta">Updated in Lang News: {{ updatedAt }}</p>{{ /if }}
      <div class="body">{{ content }}</div>
    </article>
  </main>
  <footer>
    <p class="meta">Tracked from official sources only. See the <a href="/methodology/">methodology</a>.</p>
  </footer>
</body>
</html>
